# Your fork URL (used by Jenkins and ArgoCD setup scripts)
GITHUB_REPO_URL=https://github.ibm.com/<your-username>/sre-project

# GitHub Enterprise PAT (needs 'repo' scope only)
# Create at: https://github.ibm.com/settings/tokens
GITHUB_PAT=your-pat-here

# Bob Shell API key (check Slack for your welcome message from Ask Bob)
BOBSHELL_API_KEY=your-key-here
